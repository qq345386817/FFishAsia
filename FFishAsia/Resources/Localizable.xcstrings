    "about.thanks.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All 3D models come from Sketchfab creator ffishAsia-and-floraZia, affiliated with Kyushu University biological science research."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての3DモデルはSketchfab作者ffishAsia-and-floraZia（九州大学生物科学研究機関）によるものです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有 3D 模型均来自 Sketchfab 作者 ffishAsia-and-floraZia（九州大学生物科学研究机构）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所有 3D 模型均來自 Sketchfab 作者 ffishAsia-and-floraZia（九州大学生物科学研究機构）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 3D 모델은 규슈대학교 생물과학 연구와 관련된 Sketchfab 제작자 ffishAsia-and-floraZia에서 제공됩니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle 3D-Modelle stammen vom Sketchfab-Ersteller ffishAsia-and-floraZia, verbunden mit biologischer Forschung an der Kyushu University."
          }
        }
      }
    },
