    "onboarding.1.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An AR biological model field guide for browsing Asian animals and plants in 3D and viewing them in your real space."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アジアの動植物の3Dモデルを閲覧し、現実空間にAR表示できる生物モデル図鑑です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是一个 AR 生物模型图鉴，你可以浏览亚洲生物与植物的 3D 模型，并在现实空间中查看。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這是一個 AR 生物模型圖鑑，你可以瀏覽亚洲生物與植物的 3D 模型，并在現實空間中查看。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아시아의 동물과 식물을 3D로 탐색하고 실제 공간에서 볼 수 있는 AR 생물 모델 도감입니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein AR-Feldführer für biologische Modelle, mit dem du asiatische Tiere und Pflanzen in 3D erkundest und in deinem realen Raum ansiehst."
          }
        }
      }
    },
    "onboarding.1.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to Little Nature"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さな自然へようこそ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "欢迎来到小小自然"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "歡迎來到小小自然"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Little Nature에 오신 것을 환영합니다"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Willkommen bei Little Nature"
          }
        }
      }
    },
    "onboarding.2.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Models download only when you need them, keeping the initial app lightweight. Saved content can be deleted anytime."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルは必要時に取得するため、初回インストール容量を小さく保てます。保存済みデータはいつでも削除できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模型在你需要时才会下载，不会占用初始安装包空间，已下载内容也可以随时删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模型在你需要時才會下載，不會佔用初始安装包空間，已下載內容也可以隨時刪除。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델은 필요할 때만 다운로드되어 앱을 가볍게 유지합니다. 저장된 콘텐츠는 언제든 삭제할 수 있습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelle werden nur bei Bedarf geladen, damit die App zunächst schlank bleibt. Gespeicherte Inhalte kannst du jederzeit löschen."
          }
        }
      }
    },
    "onboarding.2.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On-demand downloads save space"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "必要なときだけダウンロード"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按需下载，更省空间"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按需下載，更省空間"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "필요할 때 다운로드하여 공간 절약"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Downloads bei Bedarf sparen Speicher"
          }
        }
      }
    },
    "onboarding.3.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The app needs camera access to place and preview AR models. You can grant it when needed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ARモデルを配置・表示するためにカメラへのアクセスが必要です。必要なときに許可できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为了放置和预览 AR 模型，App 需要访问相机。你可以在需要时授权。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "为了放置和预覽 AR 模型，App 需要访问相機。你可以在需要時授權。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AR 모델을 배치하고 미리 보려면 카메라 접근 권한이 필요합니다. 필요할 때 허용할 수 있습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App benötigt Kamerazugriff, um AR-Modelle zu platzieren und anzusehen. Du kannst ihn bei Bedarf erlauben."
          }
        }
      }
    },
