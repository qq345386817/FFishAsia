    "about.download.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Model files are downloaded on demand from a remote CDN and are not installed with the app. You can check cache usage in Download Manager and delete saved content anytime."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルファイルはリモートCDNから必要時にダウンロードされ、アプリ本体には同梱されません。ダウンロード管理で容量を確認し、いつでも削除できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模型文件由远程 CDN 按需下载，不会随 App 一起安装。你可以在下载管理中查看缓存占用，并随时删除已下载内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "模型文件由遠程 CDN 按需下載，不會隨 App 一起安装。你可以在下載管理中查看缓存佔用，并隨時刪除已下載內容。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델 파일은 원격 CDN에서 필요할 때 다운로드되며 앱에 기본 포함되지 않습니다. 다운로드 관리자에서 캐시 사용량을 확인하고 저장된 콘텐츠를 언제든 삭제할 수 있습니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelldateien werden bei Bedarf von einem entfernten CDN geladen und nicht mit der App installiert. Im Download-Manager kannst du die Cache-Nutzung prüfen und gespeicherte Inhalte jederzeit löschen."
          }
        }
      }
    },
