    "about.research.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This research is affiliated with Kyushu University in Japan and aims to preserve and share biodiversity data through 3D digitization."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本研究は日本の九州大学に属し、3Dデジタル化技術によって生物多様性データを保存・共有することを目的としています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本研究隶属于日本九州大学，致力于通过 3D 数字化技术保存和传播生物多样性数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本研究隶屬於日本九州大学，致力於通過 3D 數字化技术保存和傳播生物多样性數據。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 연구는 일본 규슈대학교와 관련되어 있으며 3D 디지털화를 통해 생물다양성 데이터를 보존하고 공유하는 것을 목표로 합니다."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Forschung ist mit der Kyushu University in Japan verbunden und soll Biodiversitätsdaten durch 3D-Digitalisierung bewahren und teilen."
          }
        }
      }
    },
