    "about.source.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The 3D model resources in this app come from Sketchfab creator ffishAsia-and-floraZia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本アプリの3DモデルはSketchfabのffishAsia-and-floraZiaによるものです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本 App 内的 3D 模型资源来自 Sketchfab 作者 ffishAsia-and-floraZia。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本 App 內的 3D 模型資源來自 Sketchfab 作者 ffishAsia-and-floraZia。"
